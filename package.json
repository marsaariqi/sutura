    "icons": "node scripts/generate-icons.js",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "clean": "rimraf out dist",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run clean && npm run typecheck && electron-vite build",
    "build:win": "npm run clean && npm run typecheck && electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "postinstall": "node node_modules/electron/install.js && electron-builder install-app-deps && node scripts/generate-icons-v2.js",
    "rebuild:native": "node scripts/rebuild-native.js && node scripts/rebuild-vue.js"
